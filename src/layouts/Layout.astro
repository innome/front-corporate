---
import { Navbar } from '@components/navbar/Navbar';
import '../styles/global.scss';

const brandName = 'NIYVAL';
---
<!doctype html>
<html lang="es-CO">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<title>{brandName} — Software a la medida</title>
		<meta name="description" content="Diseñamos software a la medida y soluciones tecnológicas que potencian tu negocio. Desde Colombia, para toda Latinoamérica." />
		<meta name="keywords" content="software a la medida, desarrollo, tecnología, Colombia, automatización" />
		<meta name="author" content={brandName} />
		<link rel="icon" type="image/svg+xml" href="/favicon.ico" />
		<link rel="canonical" href="https://www.niyval.com/" />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={`${brandName} — Software a la medida`} />
		<meta property="og:description" content="Diseñamos software a la medida y soluciones tecnológicas que potencian tu negocio." />
		<meta property="og:url" content="https://www.niyval.com/" />
		<meta property="og:image" content="https://www.niyval.com/logoBlack.png" />
		<meta property="og:image:alt" content={`${brandName} — Soluciones tecnológicas a la medida`} />
		<meta property="og:locale" content="es_CO" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={`${brandName} — Software a la medida`} />
		<meta name="twitter:description" content="Diseñamos software a la medida y soluciones tecnológicas que potencian tu negocio." />
		<meta name="twitter:image" content="https://www.niyval.com/logoBlack.png" />
		<meta name="twitter:image:alt" content={`${brandName} — Soluciones tecnológicas a la medida`} />
	</head>
	<body>
		<Navbar client:load />
		<slot />
	</body>
</html>
